{
    "name": "learn-triton Dev Container (XPU-WSL)",
    "build": {
        "dockerfile": "../xpu/Dockerfile"
    },
    "runArgs": [
        "--device=/dev/dgx",
        "-v=/usr/lib/wsl:/usr/lib/wsl",
        "--privileged"
    ],
    "remoteUser": "ubuntu",
    "updateRemoteUserUID": true,
    "initializeCommand": "mkdir -p ${localEnv:HOME}/.vscode-server-devcontainers ${localEnv:HOME}/.codex-devcontainers",
    "mounts": [
        "source=${localEnv:HOME}/.vscode-server-devcontainers,target=/home/ubuntu/.vscode-server,type=bind",
        "source=${localEnv:HOME}/.codex-devcontainers,target=/home/ubuntu/.codex,type=bind"
    ]
}
